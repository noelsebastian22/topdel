---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import testimonials from '../data/testimonials.json';
import { categories, galleryItems, countFor } from '../data/gallery';
import { PHONE_DISPLAY, PHONE_TEL } from '../data/site';

import walkinOakCorner from '../assets/gallery/walkin-oak-corner.jpg';

const totalPhotos = galleryItems.length;

const services = [
  {
    name: 'Wardrobes',
    spec: 'WALK-IN · BUILT-IN · SLIDING',
    copy: 'Hanging, shelving and drawer banks arranged around how you actually dress — cut to your ceiling height, not a catalogue size.',
  },
  {
    name: 'Kitchen cabinets',
    spec: 'BENCHTOPS · SPLASHBACKS · ALFRESCO',
    copy: 'Kitchen and alfresco cabinetry with stone benchtops and splashbacks — built for the way your household actually cooks.',
  },
  {
    name: 'Office & study',
    spec: 'DESKS · SHELVING · LED DISPLAY',
    copy: 'Desks, display walls and bar nooks with built-in lighting. Made for the room you have, whether that’s a spare bedroom or an alcove.',
  },
  {
    name: 'Laundry',
    spec: 'FULL-HEIGHT · BENCH + OVERHEADS',
    copy: 'Full-height cabinetry that swallows baskets, brooms and detergent — so the hardest-working room in the house stays the tidiest.',
  },
  {
    name: 'Address face plates',
    spec: 'CUT TO MATCH YOUR FAÇADE',
    copy: 'Street numbers cut and finished to suit your home’s exterior. A small piece of joinery that sets the tone before the front door.',
  },
];

const processSteps = [
  { n: '01', name: 'Measure', copy: 'We come to you, tape in hand, and measure the room wall to wall.' },
  { n: '02', name: 'Design', copy: 'Layout and finishes agreed with you up front, with a clear price.' },
  { n: '03', name: 'Make', copy: 'Cut, edged and assembled to the drawings — to the millimetre.' },
  { n: '04', name: 'Install', copy: 'Fitted clean and level, rubbish gone, room ready to use.' },
];
---

<Layout
  title="TopDel House Decor — Custom wardrobes, office & laundry fitouts"
  description={`Custom-made wardrobes, kitchens, home office and laundry fitouts, and street address face plates — measured, made and installed by TopDel House Decor. Call ${PHONE_DISPLAY} for a free quote.`}
>
  <SiteHeader current="home" />

  <main id="top">
    <!-- ———— HERO ———— -->
    <section class="hero">
      <div class="hero-media" aria-hidden="true">
        <video
          id="heroVideo"
          poster="/media/hero-poster.jpg"
          data-src="/media/topdel-fitout-web.mp4"
          muted
          loop
          playsinline
          preload="none"
          tabindex="-1"
        ></video>
        <div class="hero-scrim"></div>
      </div>

      <!-- shop-drawing annotations -->
      <div class="dim dim-v" aria-hidden="true"><span>FLOOR TO CEILING — EVERY MM USED</span></div>
      <div class="dim dim-h" aria-hidden="true"><span>WALL TO WALL · NO FILLER PANELS</span></div>

      <div class="container hero-in">
        <p class="eyebrow eyebrow--light eyebrow--start">Custom joinery — measured · made · installed</p>
        <h1>Storage built to<br />the millimetre.</h1>
        <p class="hero-sub">
          TopDel designs, makes and installs custom wardrobes, kitchens, home office and
          laundry fitouts — cut to your room’s exact dimensions, with no wasted corners.
        </p>
        <div class="hero-cta">
          <a class="btn btn-solid magnetic" href={PHONE_TEL}>Call {PHONE_DISPLAY} — free quote</a>
          <a class="btn btn-ghost" href="#work">See recent fitouts</a>
        </div>
      </div>

      <button class="video-toggle" id="videoToggle" hidden aria-pressed="true">Pause video</button>
    </section>

    <!-- ———— ABOUT ———— -->
    <section class="about" id="about">
      <div class="container about-grid">
        <div class="about-copy" data-reveal>
          <p class="eyebrow">About TopDel</p>
          <h2>Off-the-shelf never quite fits. So we don’t sell it.</h2>
          <p>
            Every TopDel piece starts with a tape measure in your room. We design around
            your ceiling height, your skirting, your awkward corner — then cut, edge and
            assemble cabinetry that’s made to be lived in. One team measures, makes and
            installs, so nothing gets lost between the quote and the final fit.
          </p>
          <ul class="spec-list">
            <li><strong>Walk-in &amp; built-in robes</strong><span>double hang, drawer banks, shoe shelving</span></li>
            <li><strong>Home office &amp; study</strong><span>desks, display shelving, LED strips</span></li>
            <li><strong>Laundry &amp; utility</strong><span>full-height storage that hides the mess</span></li>
            <li><strong>Feature pieces</strong><span>TV walls, bars, prayer cabinets, face plates</span></li>
          </ul>
        </div>
        <figure class="about-photo" data-reveal>
          <Image
            src={walkinOakCorner}
            alt="Oak walk-in wardrobe by TopDel with shelving, double hanging and drawer banks"
            widths={[420, 640, 900]}
            sizes="(min-width: 900px) 44vw, 92vw"
            format="webp"
            quality={72}
            loading="lazy"
            decoding="async"
          />
          <figcaption>WALK-IN ROBE · OAK · INSTALLED BY TOPDEL</figcaption>
        </figure>
      </div>
    </section>

    <!-- ———— SERVICES ———— -->
    <section class="services" id="services">
      <div class="container">
        <p class="eyebrow" data-reveal>What we build</p>
        <h2 data-reveal>Five things, done properly.</h2>
        <div class="services-grid">
          {services.map((s, i) => (
            <article class="service" data-reveal style={`--i: ${i}`}>
              <p class="service-spec">{s.spec}</p>
              <h3>{s.name}</h3>
              <p>{s.copy}</p>
            </article>
          ))}
          <aside class="service service--plate" data-reveal style="--i: 5" aria-label="Example address face plate">
            <div class="plate" aria-hidden="true">
              <span class="plate-no">27</span>
              <span class="plate-street">EXAMPLE&nbsp;ST</span>
            </div>
            <p class="service-spec plate-note">FACE PLATE · POWDER-COATED · MADE TO ORDER</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- ———— PROCESS ———— -->
    <section class="process" id="process">
      <div class="container">
        <p class="eyebrow eyebrow--light" data-reveal>How it works</p>
        <h2 data-reveal>One call. Four steps. Fitted.</h2>
        <ol class="process-grid">
          {processSteps.map((p, i) => (
            <li class="p-step" data-reveal style={`--i: ${i}`}>
              <span class="step-n" aria-hidden="true">{p.n}</span>
              <h3>{p.name}</h3>
              <p>{p.copy}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ———— OUR WORK — category tiles ———— -->
    <section class="work" id="work">
      <div class="container">
        <p class="eyebrow" data-reveal>Our work</p>
        <h2 data-reveal>Real rooms, real millimetres.</h2>
        <p class="work-sub" data-reveal>
          Every photo is a TopDel install — no stock imagery. Pick a category, or browse the lot.
        </p>
        <div class="cat-grid">
          {categories.map((c, i) => (
            <a class="cat-tile" href={`/gallery?category=${c.slug}`} data-reveal style={`--i: ${i % 3}`}>
              <Image
                src={c.cover}
                alt=""
                widths={[420, 640, 900]}
                sizes="(min-width: 900px) 31vw, (min-width: 640px) 46vw, 92vw"
                format="webp"
                quality={70}
                loading="lazy"
                decoding="async"
              />
              <span class="cat-scrim" aria-hidden="true"></span>
              <span class="cat-label">
                <strong class="cat-name">{c.name}</strong>
                <span class="cat-count">{countFor(c.slug)} {countFor(c.slug) === 1 ? 'PHOTO' : 'PHOTOS'} →</span>
              </span>
            </a>
          ))}
        </div>
        <p class="work-all" data-reveal>
          <a class="btn btn-navy" href="/gallery">View all {totalPhotos} photos</a>
        </p>
      </div>
    </section>

    <!-- ———— TESTIMONIALS (mock data for client demo — swap real quotes into src/data/testimonials.json) ———— -->
    {testimonials.length > 0 && (
      <section class="quotes" id="quotes">
        <div class="container">
          <p class="eyebrow" data-reveal>Testimonials</p>
          <h2 data-reveal>What customers say about us</h2>
          <div class="quotes-grid">
            {testimonials.map((t: { quote: string; name: string; suburb: string; project: string }, i) => (
              <article class="quote-card" data-reveal style={`--i: ${i}`}>
                <span class="quote-mono" aria-hidden="true">{t.name.charAt(0)}</span>
                <blockquote>
                  <p>“{t.quote}”</p>
                </blockquote>
                <footer class="quote-meta">
                  <strong>{t.name}</strong>
                  <span>{t.project} · {t.suburb}</span>
                </footer>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ———— CONTACT ———— -->
    <section class="cta-band" id="contact">
      <div class="container contact-grid" data-reveal>
        <div class="contact-intro">
          <p class="cta-kicker">FREE QUOTE · ONE VISIT · ONE PRICE</p>
          <h2>Ready when you are.</h2>
          <p class="contact-copy">
            Tell us a little about the room and we’ll call you back to book a free
            measure — or skip the form and call us now.
          </p>
          <a class="cta-phone" href={PHONE_TEL}>{PHONE_DISPLAY}</a>
        </div>

        <form class="quote-form" id="quoteForm" method="post" novalidate>
          <div class="qf-row">
            <div class="qf-field">
              <label for="qfName">Name</label>
              <input id="qfName" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="qf-field">
              <label for="qfPhone">Phone</label>
              <input id="qfPhone" name="phone" type="tel" autocomplete="tel" required />
            </div>
          </div>
          <div class="qf-row">
            <div class="qf-field">
              <label for="qfEmail">Email <span class="qf-opt">optional</span></label>
              <input id="qfEmail" name="email" type="email" autocomplete="email" />
            </div>
            <div class="qf-field">
              <label for="qfSuburb">Suburb</label>
              <input id="qfSuburb" name="suburb" type="text" autocomplete="address-level2" required />
            </div>
          </div>
          <div class="qf-field">
            <label for="qfType">Project type</label>
            <select id="qfType" name="project" required>
              <option value="" disabled selected>Choose one…</option>
              {services.map((s) => (
                <option value={s.name}>{s.name}</option>
              ))}
              <option value="Something else">Something else</option>
            </select>
          </div>
          <div class="qf-field">
            <label for="qfDetails">Project details <span class="qf-opt">room, rough sizes, finishes — anything helps</span></label>
            <textarea id="qfDetails" name="details" rows="4"></textarea>
          </div>
          <!-- honeypot — hidden from real visitors -->
          <input class="qf-hp" type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button class="btn btn-navy qf-submit" type="submit">Request a free quote</button>
          <p class="qf-status" id="qfStatus" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* ———— hero ———— */
  .hero {
    position: relative; min-height: 100svh;
    display: grid; align-items: center;
    background: var(--ink); /* paints before poster loads — no flash, no CLS */
    overflow: hidden;
  }
  .hero-media { position: absolute; inset: 0; }
  .hero-media video {
    width: 100%; height: 118%; object-fit: cover;
    background: var(--ink) url('/media/hero-poster.jpg') center / cover no-repeat;
    will-change: transform;
  }
  .hero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(78deg, rgba(15, 34, 64, 0.9) 18%, rgba(15, 34, 64, 0.55) 52%, rgba(15, 34, 64, 0.25) 100%);
  }
  .hero-in { position: relative; padding-block: 8rem 6rem; }
  .hero h1 {
    color: var(--white);
    font-size: clamp(2.6rem, 7.2vw, 5.2rem);
    font-weight: 850; font-stretch: 122%;
    margin-bottom: 1.4rem;
  }
  .hero-sub { color: rgba(255, 255, 255, 0.85); max-width: 34rem; font-size: 1.15rem; margin-bottom: 2.2rem; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .magnetic { will-change: transform; }

  /* shop-drawing dimension annotations */
  .dim { position: absolute; z-index: 2; color: rgba(255, 255, 255, 0.85); pointer-events: none; }
  .dim span { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; }
  .dim-v { right: clamp(1.5rem, 5vw, 4.5rem); top: 14svh; height: 62svh; border-left: 1px solid rgba(255, 255, 255, 0.55); }
  .dim-v::before, .dim-v::after { content: ''; position: absolute; left: -7px; width: 15px; height: 1px; background: rgba(255, 255, 255, 0.55); }
  .dim-v::before { top: 0; } .dim-v::after { bottom: 0; }
  .dim-v span { position: absolute; top: 50%; left: 0.6rem; transform: rotate(180deg) translateY(50%); writing-mode: vertical-rl; }
  .dim-h { left: var(--gutter); right: 40%; bottom: 5svh; border-top: 1px solid rgba(255, 255, 255, 0.55); }
  .dim-h::before, .dim-h::after { content: ''; position: absolute; top: -7px; height: 15px; width: 1px; background: rgba(255, 255, 255, 0.55); }
  .dim-h::before { left: 0; } .dim-h::after { right: 0; }
  .dim-h span { display: inline-block; padding-top: 0.5rem; }
  @media (max-width: 899px) { .dim { display: none; } }

  .video-toggle {
    position: absolute; right: 1.2rem; bottom: 1.2rem; z-index: 3;
    background: rgba(15, 34, 64, 0.7); color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.4); border-radius: var(--radius);
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.12em;
    padding: 0.45rem 0.8rem;
  }

  /* ———— about ———— */
  .about { padding-block: clamp(4.5rem, 9vw, 7.5rem); }
  .about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(2.5rem, 6vw, 5rem); align-items: center; }
  .about h2 { font-size: clamp(1.9rem, 3.6vw, 2.8rem); margin-bottom: 1.1rem; }
  .spec-list { list-style: none; padding: 0; margin-top: 2rem; border-top: 1px solid var(--line); }
  .spec-list li {
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: 0.3rem 1.5rem;
    padding: 0.85rem 0; border-bottom: 1px solid var(--line);
  }
  .spec-list strong { color: var(--ink); font-weight: 650; }
  .spec-list span { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--blue); align-self: center; }
  .about-photo { position: relative; }
  .about-photo img { border-radius: var(--radius); aspect-ratio: 3 / 4; object-fit: cover; width: 100%; height: auto; }
  .about-photo figcaption {
    margin-top: 0.7rem; font-family: var(--font-mono); font-size: 0.66rem;
    letter-spacing: 0.18em; color: var(--blue);
  }

  /* ———— services ———— */
  .services { padding-block: clamp(4.5rem, 9vw, 7.5rem); background: var(--tint); }
  .services h2 { font-size: clamp(1.9rem, 3.6vw, 2.8rem); margin-bottom: 2.4rem; }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .service {
    background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.7rem 1.6rem 1.9rem;
  }
  .service-spec { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.16em; color: var(--blue); margin-bottom: 0.9rem; }
  .service h3 { font-size: 1.35rem; margin-bottom: 0.6rem; }
  .service p:last-child { font-size: 0.98rem; }
  .service--plate {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.2rem;
    background: var(--ink); border-color: var(--ink);
  }
  /* five service cards + the plate demo fill the 3×2 grid exactly — no spanning needed */
  .plate {
    background: var(--ink); border: 3px solid var(--yellow); border-radius: 10px;
    padding: 1.1rem 1.9rem; text-align: center;
    box-shadow: 0 10px 30px rgba(15, 34, 64, 0.45);
  }
  .plate-no { display: block; font-family: var(--font-display); font-weight: 900; font-stretch: 125%; font-size: 3.2rem; line-height: 1; color: var(--yellow); }
  .plate-street { display: block; margin-top: 0.4rem; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.34em; color: var(--white); }
  .plate-note { color: rgba(255, 255, 255, 0.75); margin: 0; }

  /* ———— process ———— */
  .process { padding-block: clamp(4.5rem, 9vw, 7.5rem); background: var(--ink); }
  .process h2 { color: var(--white); font-size: clamp(1.9rem, 3.6vw, 2.8rem); margin-bottom: 2.4rem; }
  .process-grid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; counter-reset: step; }
  .process-grid li { position: relative; border-top: 1px solid rgba(255, 255, 255, 0.25); padding-top: 1.1rem; }
  /* crisper struck rule that draws over the faint baseline — neutral, never yellow */
  .p-step::before {
    content: ''; position: absolute; top: -1px; left: 0;
    width: 100%; height: 1px; background: rgba(255, 255, 255, 0.6);
    transform-origin: left;
  }
  .step-n { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.2em; color: var(--yellow); }
  .process-grid h3 { color: var(--white); font-size: 1.25rem; margin: 0.5rem 0 0.4rem; }
  .process-grid p { color: rgba(255, 255, 255, 0.72); font-size: 0.95rem; }

  /* ———— our work — category tiles ———— */
  .work { padding-block: clamp(4.5rem, 9vw, 7.5rem); }
  .work h2 { font-size: clamp(1.9rem, 3.6vw, 2.8rem); }
  .work-sub { margin: 0.7rem 0 2.4rem; }
  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .cat-tile {
    position: relative; display: block; overflow: hidden;
    border-radius: var(--radius); text-decoration: none;
  }
  .cat-tile img { width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: cover; transition: transform 0.5s ease; }
  .cat-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(15, 34, 64, 0) 38%, rgba(15, 34, 64, 0.82) 100%);
  }
  .cat-label {
    position: absolute; inset: auto 0 0;
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 1.1rem 1.2rem 1rem;
  }
  .cat-name {
    font-family: var(--font-display); font-weight: 800; font-stretch: 115%;
    font-size: 1.3rem; line-height: 1.1; color: var(--white);
  }
  .cat-count { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.16em; color: var(--yellow); }
  @media (prefers-reduced-motion: no-preference) {
    .cat-tile:hover img, .cat-tile:focus-visible img { transform: scale(1.04); }
  }
  .work-all { margin-top: 2rem; }

  /* ———— testimonials ———— */
  .quotes { padding-block: clamp(4.5rem, 9vw, 7.5rem); background: var(--tint); }
  .quotes h2 { font-size: clamp(1.9rem, 3.6vw, 2.8rem); margin-bottom: 2.4rem; }
  .quotes-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .quote-card {
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; gap: 1rem;
    background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.7rem 1.5rem 1.6rem;
  }
  /* blueprint rule that draws itself across the card's top edge on reveal */
  .quote-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 100%; height: 3px; background: var(--blue);
    transform-origin: left;
  }
  /* drafting-style monogram — stands in for the avatar, no stock faces */
  .quote-mono {
    display: grid; place-items: center; flex: none;
    width: 46px; height: 46px; border-radius: 50%;
    background: var(--tint); color: var(--blue); border: 1px solid var(--line);
    font-family: var(--font-display); font-weight: 800; font-stretch: 115%; font-size: 1.25rem;
  }
  .quote-card blockquote { margin: 0; }
  .quote-card blockquote p { color: var(--ink); font-size: 0.98rem; }
  .quote-meta { margin-top: auto; display: flex; flex-direction: column; gap: 0.35rem; }
  .quote-meta strong { font-family: var(--font-display); font-weight: 700; color: var(--ink); font-size: 1.02rem; }
  .quote-meta span {
    font-family: var(--font-mono); font-size: 0.64rem;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--blue);
  }

  /* ———— contact / CTA band ———— */
  .cta-band { background: var(--yellow); padding-block: clamp(3.5rem, 7vw, 5.5rem); }
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4.5rem); align-items: start;
  }
  .cta-kicker { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.2em; color: var(--ink); margin-bottom: 0.5rem; }
  .cta-band h2 { font-size: clamp(2rem, 4.5vw, 3.2rem); }
  .contact-copy { color: var(--ink); margin: 1rem 0 1.8rem; max-width: 26rem; }
  .cta-phone {
    font-family: var(--font-display); font-weight: 900; font-stretch: 120%;
    font-size: clamp(1.9rem, 5vw, 3.4rem); color: var(--ink); text-decoration: none;
    border-bottom: 4px solid var(--ink); line-height: 1.15;
  }
  .cta-phone:hover { border-bottom-color: var(--blue); color: var(--blue); }

  /* quote form */
  .quote-form {
    background: var(--white); border-radius: var(--radius);
    padding: clamp(1.4rem, 3vw, 2.2rem);
    box-shadow: 0 14px 40px rgba(15, 34, 64, 0.18);
  }
  .qf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .qf-field { margin-bottom: 1rem; }
  .qf-field label {
    display: block; margin-bottom: 0.35rem;
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink);
  }
  .qf-opt { color: var(--slate); text-transform: none; letter-spacing: 0.06em; }
  .qf-field input,
  .qf-field select,
  .qf-field textarea {
    width: 100%; padding: 0.7rem 0.85rem;
    font: inherit; font-size: 1rem; color: var(--ink);
    background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
  }
  .qf-field textarea { resize: vertical; min-height: 6.5rem; }
  .qf-field input:focus-visible,
  .qf-field select:focus-visible,
  .qf-field textarea:focus-visible { outline: 3px solid var(--blue); outline-offset: 1px; }
  .qf-hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .qf-submit { width: 100%; margin-top: 0.4rem; }
  .qf-status { margin: 0.8rem 0 0; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em; color: var(--ink); }
  .qf-status:empty { display: none; }
  .qf-status.error { color: var(--fault); }

  /* ———— responsive ———— */
  @media (max-width: 899px) {
    .about-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .process-grid { grid-template-columns: 1fr 1fr; gap: 1.6rem 1.2rem; }
    .cat-grid { grid-template-columns: 1fr 1fr; }
    .quotes-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 599px) {
    .services-grid { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: 1fr; }
    .cat-grid { grid-template-columns: 1fr; }
    .quotes-grid { grid-template-columns: 1fr; }
    .hero-in { padding-block: 7rem 4.5rem; }
    .qf-row { grid-template-columns: 1fr; gap: 0; }
  }
</style>

<script>
  const doc = document;
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)');
  const finePointer = matchMedia('(pointer: fine)');
  const desktop = matchMedia('(min-width: 900px)');

  /* ——— scroll reveals ——— */
  const revealEls = Array.from(doc.querySelectorAll('[data-reveal]'));
  if (reduceMotion.matches || !('IntersectionObserver' in window)) {
    revealEls.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -36px' }
    );
    revealEls.forEach((el) => io.observe(el));
  }

  /* ——— hero video: desktop only, motion-safe, respects Save-Data ——— */
  const video = doc.getElementById('heroVideo') as HTMLVideoElement | null;
  const saveData = (navigator as any).connection?.saveData === true;
  let videoLoaded = false;
  if (video && desktop.matches && !reduceMotion.matches && !saveData) {
    video.src = video.dataset.src!;
    video.play().catch(() => {});
    videoLoaded = true;

    const toggle = doc.getElementById('videoToggle') as HTMLButtonElement;
    toggle.hidden = false;
    toggle.addEventListener('click', () => {
      const playing = !video.paused;
      playing ? video.pause() : video.play();
      toggle.textContent = playing ? 'Play video' : 'Pause video';
      toggle.setAttribute('aria-pressed', String(!playing));
    });
  }

  /* ——— hero parallax (desktop + motion-safe only) ——— */
  if (video && videoLoaded) {
    let ticking = false;
    addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = scrollY;
          if (y < innerHeight) video.style.transform = `translateY(${y * 0.16}px)`;
          ticking = false;
        });
      },
      { passive: true }
    );
  }

  /* ——— magnetic primary CTA (fine pointer + motion-safe only) ——— */
  const mag = doc.querySelector('.magnetic') as HTMLElement | null;
  if (mag && finePointer.matches && desktop.matches && !reduceMotion.matches) {
    mag.addEventListener('mousemove', (e) => {
      const r = mag.getBoundingClientRect();
      const x = e.clientX - r.left - r.width / 2;
      const y = e.clientY - r.top - r.height / 2;
      mag.style.transform = `translate(${x * 0.16}px, ${y * 0.16}px)`;
    });
    mag.addEventListener('mouseleave', () => {
      mag.style.transform = '';
    });
  }

  /* ——— quote form ——— */
  // TODO: set to the real form endpoint before go-live (e.g. Formspree: https://formspree.io/f/XXXXXXXX)
  const FORM_ENDPOINT = '';
  const form = doc.getElementById('quoteForm') as HTMLFormElement | null;
  const status = doc.getElementById('qfStatus') as HTMLParagraphElement | null;
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // honeypot — silently drop bot submissions
      const hp = form.elements.namedItem('company') as HTMLInputElement;
      if (hp?.value) return;

      if (!form.reportValidity()) return;

      const submit = form.querySelector('.qf-submit') as HTMLButtonElement;
      const fail = () => {
        status.classList.add('error');
        status.textContent = 'SOMETHING WENT WRONG — PLEASE CALL 043 000 6015 INSTEAD.';
      };

      if (!FORM_ENDPOINT) {
        fail();
        return;
      }

      submit.disabled = true;
      status.classList.remove('error');
      status.textContent = 'SENDING…';
      try {
        const res = await fetch(FORM_ENDPOINT, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        status.textContent = 'THANKS — WE’LL CALL YOU BACK WITHIN ONE BUSINESS DAY.';
      } catch {
        fail();
      } finally {
        submit.disabled = false;
      }
    });
  }

</script>
