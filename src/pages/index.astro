    .hero-in { padding-block: 7rem 4.5rem; }
    .hero-services { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem 1rem; }
    .hero-services a { padding-inline: 0; }
    .hero-services a + a { border-left: 0; }
    /* tall phone crop: centre on the hanging rail, not the empty wall */
    .hero-media img { object-position: 60% 50%; }
    .qf-row { grid-template-columns: 1fr; gap: 0; }
    /* Stack + equalise the call/WhatsApp buttons so they don't sit at
       mismatched widths on narrow screens */
    .contact-buttons { flex-direction: column; align-items: stretch; }
    .contact-btn { justify-content: center; }
  }
</style>

<script>
  const doc = document;
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)');
  const finePointer = matchMedia('(pointer: fine)');
  const desktop = matchMedia('(min-width: 900px)');

  /* ——— scroll reveals ——— */
  const revealEls = Array.from(doc.querySelectorAll('[data-reveal]'));
  if (reduceMotion.matches || !('IntersectionObserver' in window)) {
    revealEls.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -36px' }
    );
    revealEls.forEach((el) => io.observe(el));
  }

  /* ——— hero parallax (desktop + motion-safe only) ——— */
  const heroImg = doc.querySelector('.hero-media img') as HTMLElement | null;
  if (heroImg && desktop.matches && !reduceMotion.matches) {
    let ticking = false;
    addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = scrollY;
          if (y < innerHeight) video.style.transform = `translateY(${y * 0.16}px)`;
          ticking = false;
        });
      },
      { passive: true }
    );
  }

  /* ——— magnetic primary CTA (fine pointer + motion-safe only) ——— */
  const mag = doc.querySelector('.magnetic') as HTMLElement | null;
  if (mag && finePointer.matches && desktop.matches && !reduceMotion.matches) {
    mag.addEventListener('mousemove', (e) => {
      const r = mag.getBoundingClientRect();
      const x = e.clientX - r.left - r.width / 2;
      const y = e.clientY - r.top - r.height / 2;
      mag.style.transform = `translate(${x * 0.16}px, ${y * 0.16}px)`;
    });
    mag.addEventListener('mouseleave', () => {
      mag.style.transform = '';
    });
  }

  /* ——— quote form — Web3Forms (https://web3forms.com) ——— */
  // Access key is tied to sales@topdelrenovation.com.au — submissions are emailed there.
  // Web3Forms keys are public by design, safe to ship client-side.
  const FORM_ENDPOINT = 'https://api.web3forms.com/submit';
  const WEB3FORMS_KEY = '324cd749-00f5-4139-bef7-68e29a07b3cc';
  const form = doc.getElementById('quoteForm') as HTMLFormElement | null;
  const status = doc.getElementById('qfStatus') as HTMLParagraphElement | null;
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // honeypot — silently drop bot submissions
      const hp = form.elements.namedItem('company') as HTMLInputElement;
      if (hp?.value) return;

      if (!form.reportValidity()) return;

      const submit = form.querySelector('.qf-submit') as HTMLButtonElement;
      const fail = () => {
        status.classList.add('error');
        status.textContent = 'SOMETHING WENT WRONG — PLEASE CALL 0430 006 015 INSTEAD.';
      };

      // guard until the real Web3Forms access key is in place
      if (WEB3FORMS_KEY.startsWith('TODO')) {
        fail();
        return;
      }

      submit.disabled = true;
      status.classList.remove('error');
      status.textContent = 'SENDING…';
      try {
        const data = new FormData(form);
        data.append('access_key', WEB3FORMS_KEY);
        data.append('subject', 'New quote request — topdelrenovation website');
        data.append('from_name', 'TopDel website quote form');
        const res = await fetch(FORM_ENDPOINT, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        status.textContent = 'THANKS — WE’LL CALL YOU BACK WITHIN ONE BUSINESS DAY.';
      } catch {
        fail();
      } finally {
        submit.disabled = false;
      }
    });
  }

</script>
